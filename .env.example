# ─────────────────────────────────────
#  AI Knowledge Drive — Environment
# ─────────────────────────────────────

# ── App ──────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── MongoDB ───────────────────────────
MONGO_URI=mongodb://localhost:27017/au-drive
# Production: MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/au-drive

# ── Redis ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudflare R2 ─────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=au-drive-files
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<hash>.r2.dev   # Optional: public bucket URL

# ── AI Service ────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── File Limits ───────────────────────
MAX_FILE_SIZE_MB=100
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ── AI Keys (Phase 2+) ────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Rate Limiting ─────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_MAX_AI=10

# ── Storage Quota ─────────────────────
DEFAULT_STORAGE_QUOTA_GB=15
